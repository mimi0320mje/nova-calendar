rules_version = '2';
// Each signed-in user can read/write ONLY their own profile + events.
// Nobody can touch anyone else's data. The Admin SDK (Cloud Functions and the
// local add-event helper) bypasses these rules with full access.
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;

      match /events/{eventId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }
  }
}
